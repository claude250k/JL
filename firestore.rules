rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Posts: jeder angemeldete User kann lesen, nur eigene erstellen/bearbeiten
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null; // für likes
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    // Users: jeder kann lesen, nur eigenes Profil bearbeiten
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // Votes: anonym, jeder angemeldete User
    match /votes/{partyId} {
      allow read, write: if request.auth != null;
    }
    match /userVotes/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
